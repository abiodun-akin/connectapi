# Environment Configuration - Development Template

# Backend API
PORT=8888
NODE_ENV=development

# Database
CONN_STR=mongodb://connectapi:connectapi@mongodb:27017/connectdb?authSource=admin

# JWT
JWT_SECRET=dev-secret-key-change-in-production-12345678901234567890

# Frontend
FRONTEND_ORIGIN=http://localhost:5173

# Super Admin (optional in dev, required in production)
SUPER_ADMIN_EMAIL=superadmin@farmconnect.local
SUPER_ADMIN_PASSWORD=Admin12345
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_ROTATE_PASSWORD=false

# Paystack (Get from https://dashboard.paystack.com)
# For local testing, use test keys
PAYSTACK_SECRET_KEY=sk_test_f72f76eaaf00b08e89a3ad8b58b49462eda650ea
PAYSTACK_PUBLIC_KEY=pk_test_f7ea1bcbca3e7b0c084a976f25efb60892a484b9
VITE_PAYSTACK_PUBLIC_KEY=pk_test_f7ea1bcbca3e7b0c084a976f25efb60892a484b9

# RabbitMQ (use local)
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# Email Service (use Resend.com)
RESEND_API_KEY=re_test_key_here
RESEND_FROM_EMAIL=noreply@kwezitechnologiesltd.africa

# SMS Service (use beem.africa - optional, SMS disabled by default)
BEEM_API_KEY=
BEEM_SECRET_KEY=
BEEM_FROM_NAME=FarmConnect

# Push Notifications (Firebase - optional, push disabled by default)
FIREBASE_SERVICE_ACCOUNT=

# Cron Jobs Secret
CRON_SECRET=dev-cron-secret-change-in-production

# Public app URL used in email links
APP_URL=https://your-frontend-domain.com

# Free scheduler targets
# POST /api/cron/process-notifications
# POST /api/cron/process-trials
# POST /api/cron/cancel-overdue

# Vite (Frontend)
VITE_API_URL=http://localhost:8888/api

# Logging
LOG_LEVEL=debug
