# Environment Configuration - Production Template

# Backend API
PORT=8888
NODE_ENV=production

# Database - Use strong credentials in production
CONN_STR=mongodb://username:password@mongodb:27017/connectdb_prod?authSource=admin

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend
FRONTEND_ORIGIN=https://your-domain.com

# Super Admin (required in production to bootstrap admin dashboard access)
SUPER_ADMIN_EMAIL=superadmin@your-domain.com
SUPER_ADMIN_PASSWORD=ChangeThisStrongPassword123
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_ROTATE_PASSWORD=false

# Paystack (Get from https://dashboard.paystack.com)
# Use LIVE keys in production
PAYSTACK_SECRET_KEY=sk_live_your_live_secret_key
PAYSTACK_PUBLIC_KEY=pk_live_your_live_public_key
VITE_PAYSTACK_PUBLIC_KEY=pk_live_your_live_public_key

# RabbitMQ (use CloudAMQP or professional hosting)
RABBITMQ_URL=amqps://username:password@your-rabbitmq-host.com/

# Email Service (use Resend.com or similar)
RESEND_API_KEY=re_your_production_key

# Cron Jobs Secret
CRON_SECRET=your-production-cron-secret

# Logging
LOG_LEVEL=warn

# MongoDB Credentials
MONGO_USERNAME=connectapi
MONGO_PASSWORD=your-secure-password
